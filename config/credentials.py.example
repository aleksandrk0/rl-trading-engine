# config/credentials.py.example
# Скопируйте этот файл в config/credentials.py и впишите свои значения.
# РЕАЛЬНЫЙ config/credentials.py НЕ коммитится в git (см. .gitignore).

MT5_LOGIN = 00000000              # ваш логин MetaTrader5
MT5_PASSWORD = "your-password"    # пароль MetaTrader5
MT5_SERVER = "Your-Broker-Server" # сервер брокера

# Ключи биржи Bybit берутся из переменных окружения (.env), НЕ хардкодом:
#   BYBIT_API_KEY=...
#   BYBIT_API_SECRET=...
